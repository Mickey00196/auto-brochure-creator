# Defaults to a local SQLite file if unset — set this to Postgres in
# production (Render's managed Postgres, Supabase, etc).
DATABASE_URL=sqlite:///./phishguard_realestate.db

# Signs the login JWT — generate with `python -c "import secrets; print(secrets.token_hex(32))"`.
# Every deployment MUST override this; the code falls back to an insecure
# dev-only value if unset so `pytest` and local runs work with zero setup.
JWT_SECRET_KEY=change-me-to-a-random-secret

# Optional — region map pages on the PPTX/PDF fall back to no map if unset.
GOOGLE_MAPS_API_KEY=
